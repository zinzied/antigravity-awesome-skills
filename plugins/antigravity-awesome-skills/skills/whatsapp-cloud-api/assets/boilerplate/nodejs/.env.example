# WhatsApp Cloud API Configuration
# Obtenha estes valores em: https://developers.facebook.com > App > WhatsApp > API Setup

# Token de acesso (System User Token para producao)
WHATSAPP_TOKEN=your_access_token_here

# ID do numero de telefone (encontrado no API Setup)
PHONE_NUMBER_ID=your_phone_number_id

# ID da conta WhatsApp Business (encontrado no API Setup)
WABA_ID=your_waba_id

# App Secret (encontrado em App Settings > Basic)
APP_SECRET=your_app_secret

# Token customizado para verificacao do webhook (voce define)
VERIFY_TOKEN=your_custom_verify_token

# Porta do servidor
PORT=3000
